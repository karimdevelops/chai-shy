{
    "version": 2,
    "installCommand": "pnpm install && cd api && pnpm install && cd ../client && pnpm install",
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/src/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}