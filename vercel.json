{
    "version": 2,
    "packageManager": "@10.33.0",
    "installCommand": "cd client && pnpm install",
    "buildCommand": "cd client && pnpm run build",
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/src/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}